/* Общие стили */
body {
  font-family: Arial, sans-serif;
  background-color: #f0f0f0;
  margin: 0;
  padding: 20px;
}

/* Заголовки и подвал */
header, footer {
  background-color: #333;
  color: white;
  padding: 10px;
  text-align: center;
}

/* Основной раздел */
section {
  margin: 20px 0;
}

/* Адаптивные стили */
@media (max-width: 600px) {
  body {
    padding: 10px;
  }
  h1 {
    font-size: 24px;
  }
  p {
    font-size: 16px;
  }
}